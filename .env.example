# Daraja API Environment
# Copy this file to .env and fill in your values from https://developer.safaricom.co.ke/MyApps

DARAJA_ENVIRONMENT=sandbox

# Generated when you create an app on the Daraja portal
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here

# Your M-Pesa shortcode (PayBill or Till number)
DARAJA_SHORTCODE=174379

# Provided by Safaricom per shortcode — sandbox has a shared test passkey
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Required for B2C, B2B, Transaction Status, Account Balance, and Reversal
DARAJA_INITIATOR_NAME=testapi
DARAJA_INITIATOR_PASSWORD=Safaricom999!*!

# Callback URLs — use `daraja webhook serve` during development for a local tunnel
DARAJA_CALLBACK_URL=https://your-server.com/api/mpesa/callback
DARAJA_VALIDATION_URL=https://your-server.com/api/mpesa/validation
DARAJA_CONFIRMATION_URL=https://your-server.com/api/mpesa/confirmation
